{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "trailingSlash": true,
  "cleanUrls": true,
  "redirects": [
    { "source": "/blog/how-to-measure-ai-search-visibility", "destination": "/blog/ai-visibility-measurement-guide", "permanent": true },
    { "source": "/blog/llm-seo-vs-traditional-seo", "destination": "/blog/llm-visibility-vs-traditional-seo", "permanent": true },
    { "source": "/blog/how-to-audit-your-website-for-ai-search-readiness", "destination": "/blog/ai-search-readiness-audit", "permanent": true },
    { "source": "/ai-seo-general-insurance-chatgpt-benchmark", "destination": "/blog/category/ai-visibility-benchmarks", "permanent": true },

    { "source": "/chatgpt-as-gtm-strategist-llmclicks-case-study", "destination": "/blog/chatgpt-as-gtm-strategist-llmclicks-case-study", "permanent": true },
    { "source": "/ai-visibility-benchmark-general-insurance-2025", "destination": "/blog/ai-visibility-benchmark-general-insurance-2025", "permanent": true },
    { "source": "/ai-visibility-benchmark-general-insurance-india-2025", "destination": "/blog/ai-visibility-benchmark-general-insurance-india-2025", "permanent": true },

    { "source": "/category/ai-visibility-benchmark", "destination": "/blog/category/ai-visibility-benchmarks", "permanent": true },
    { "source": "/blog/category/latest-updates", "destination": "/blog/category/product-updates", "permanent": true },
    { "source": "/category/learning", "destination": "/blog/category/guides", "permanent": true },
    { "source": "/category/learning/feed", "destination": "/blog/category/guides", "permanent": true },
    { "source": "/docs-category/free-tools", "destination": "/docs", "permanent": true },

    { "source": "/tag/insurance-marketing-2025", "destination": "/blog/ai-visibility-benchmark-general-insurance-usa-2025", "permanent": true },
    { "source": "/tag/ai-seo-for-insurance", "destination": "/blog/ai-visibility-benchmark-general-insurance-usa-2025", "permanent": true },
    { "source": "/tag/ai-visibility-benchmark", "destination": "/blog/category/ai-visibility-benchmarks", "permanent": true },
    { "source": "/tag/llmclicks-ai", "destination": "/", "permanent": true },

    { "source": "/support", "destination": "/contact", "permanent": true },
    { "source": "/author/llmclicks", "destination": "/author/shripad-deshmukh", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "post_type", "value": "web-story" }], "destination": "/web-stories", "permanent": true },

    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "global-footer-2" }], "destination": "/", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "docs-category" }], "destination": "/", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "elementor-header-6690" }], "destination": "/", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "global-kit-styles" }], "destination": "/", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "knowledge-hub-main-index" }], "destination": "/knowledge-hub", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "knowledge-hub-silo-pillar" }], "destination": "/knowledge-hub", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "knowledge-hub-single-article" }], "destination": "/knowledge-hub", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "llmclicks-ai-global-blog-post-template" }], "destination": "/blog", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "search-results" }], "destination": "/", "permanent": true },
    { "source": "/", "has": [{ "type": "query", "key": "elementor_library", "value": "web-stories-archive" }], "destination": "/web-stories", "permanent": true },
    { "source": "/blog/updates", "destination": "/blog/category/product-updates", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/wp-admin/:path*", "destination": "/api/gone" },
    { "source": "/wp-content/plugins/:path*", "destination": "/api/gone" },
    
    { "source": "/:file(wp-[^/]+\\.php)", "destination": "/api/gone" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
